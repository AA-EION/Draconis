    <app appid="com.codeweavers.c4.19364" timestamp="2025-05-02T15:34:15-05:00">
      <cxversion product="cxoffice">22</cxversion>
      <name>d3dcompiler_47 (64-bit)</name>
      <name lang="en">d3dcompiler_47 (64-bit)</name>
      <appprofile>
        <description>64-bit version of d3dcompiler_47.dll</description>
        <description lang="en">64-bit version of d3dcompiler_47.dll</description>
        <comment>4/1/24 - Correct download URL - Tim</comment>
        <category>Non-Applications/Components</category>
        <flag>component</flag>
        <bottletemplate>win7_64</bottletemplate>
        <bottletemplate>win10_64</bottletemplate>
        <downloadurl>https://github.com/mozilla/fxc2/raw/master/dll/d3dcompiler_47.dll</downloadurl>
        <downloadpageurl>https://github.com/mozilla/fxc2/tree/master/dll</downloadpageurl>
      </appprofile>
      <installprofile>
        <comment>5/2/2025 - Set to a n,b override (Tim)</comment>
        <installerglob>:stop:</installerglob>
        <filestocopy>
          <glob>:installer:</glob>
          <dst>%WinSysDir64%\d3dcompiler_47.dll</dst>
        </filestocopy>
        <prermfakedll>d3dcompiler_47.dll</prermfakedll>
        <preinstallregistry>
          <key>HKEY_CURRENT_USER\Software\Wine\DllOverrides</key>
          <value>
            <name>d3dcompiler_47</name>
            <data>native,builtin</data>
          </value>
        </preinstallregistry>
      </installprofile>
    </app>
